generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderCategory {
  CNC
  PRINT_3D
  LASER
  ASSEMBLY
  ELECTRICAL
  OTHER
}

enum OrderStatus {
  NEW
  QUEUED
  IN_PROGRESS
  WAITING_ON_PARTS
  DONE
  BLOCKED
  CANCELLED
}

enum BookmarkKind {
  TEMPLATE
  SITE
}

model Order {
  id               String        @id @default(uuid())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  title            String
  description      String?
  requesterName    String
  requesterContact String?
  vendor           String?
  orderNumber      String?
  orderUrl         String?
  quantity         Int?
  category         OrderCategory
  priority         Int           @default(3)
  etaDays          Int           @default(10)
  etaTargetDate    DateTime?
  status           OrderStatus   @default(NEW)
  isDeleted        Boolean       @default(false)
  notesFromManu    String?
  createdByLabel   String?
  activities       OrderActivity[]
  attachments      OrderAttachment[]
}

model Bookmark {
  id                 String         @id @default(uuid())
  kind               BookmarkKind   @default(TEMPLATE)
  name               String
  siteUrl            String?
  siteVendorHint     String?
  defaultVendor      String?
  defaultOrderUrl    String?
  defaultCategory    OrderCategory?
  defaultDescription String?
  isDeleted          Boolean       @default(false)
  createdByLabel     String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([createdByLabel, isDeleted, kind, createdAt])
}

model OrderActivity {
  id      String   @id @default(uuid())
  orderId String?
  at      DateTime @default(now())
  role    String
  action  String
  details String
  order   Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, at])
  @@index([role, at])
}

model OrderAttachment {
  id           String   @id @default(uuid())
  orderId      String
  originalName String
  storagePath  String   @unique
  contentType  String?
  sizeBytes    Int
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model LoginAttempt {
  id        String   @id @default(uuid())
  scope     String   @default("login")
  email     String
  ipAddress String
  createdAt DateTime @default(now())
  success   Boolean  @default(false)

  @@index([scope, ipAddress, createdAt])
  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}
